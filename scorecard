<!DOCTYPE html>
<html>
<head>
<title>Prudence Scorecard</title>
<style>
body{
font-family: Arial, sans-serif;
margin:40px;
background:#f7f7f7;
}

h1{
text-align:center;
}

table{
width:100%;
border-collapse:collapse;
background:white;
}

th,td{
border:1px solid #ddd;
padding:10px;
text-align:left;
}

th{
background:#eee;
}

select{
width:60px;
}

.result{
margin-top:20px;
padding:15px;
background:white;
border:1px solid #ddd;
}

button{
padding:10px 20px;
font-size:16px;
margin-top:10px;
}
</style>
</head>

<body>

<h1>Prudence Self-Assessment</h1>
<p>Rate yourself from <b>1 (Very Weak)</b> to <b>8 (Very Strong)</b></p>

<table>
<tr>
<th>#</th>
<th>Characteristic</th>
<th>Score</th>
<th>Reflection Question</th>
</tr>

<script>
const questions = [
["Be Self-Controlled","Do I control my reactions, especially when offended or embarrassed?"],
["Be Selective in Speech","Do I think before I speak and avoid unnecessary or harmful words?"],
["Be Thoughtful in Action","Do I act intentionally with understanding, or do I act impulsively?"],
["Be Discerning","Do I evaluate information carefully before making decisions?"],
["Be Teachable","Am I open to correction and willing to learn from others?"],
["Be Kind in Speech","Do my words reflect kindness, gentleness, and clarity?"],
["Be Eager to Learn","Am I actively seeking knowledge and growing in wisdom?"],
["Be Forward-Looking","Do I anticipate outcomes and prepare wisely for the future?"]
];

document.write(questions.map((q,i)=>`
<tr>
<td>${i+1}</td>
<td>${q[0]}</td>
<td>
<select class="score">
<option value="0">-</option>
${[1,2,3,4,5,6,7,8].map(n=><option>${n}</option>)}
</select>
</td>
<td>${q[1]}</td>
</tr>
`).join(""));
</script>

</table>

<button onclick="calculateScore()">Calculate Score</button>

<div class="result">
<h3>Total Score: <span id="total">0</span></h3>
<h3>Result: <span id="resultText">---</span></h3>
</div>

<div class="result">
<h3>Reflection</h3>
<p>Top 2 strengths:</p>
<input type="text" style="width:100%">

<p>Top 2 areas to improve:</p>
<input type="text" style="width:100%">

<p>One action step this week:</p>
<input type="text" style="width:100%">
</div>

<script>

function calculateScore(){

let scores=document.querySelectorAll(".score");

let total=0;

scores.forEach(s=>{
total+=parseInt(s.value);
});

document.getElementById("total").innerText=total;

let result="";

if(total>=56) result="Strong in prudence (consistently practicing wisdom)";
else if(total>=40) result="Growing in prudence (good foundation, room to mature)";
else if(total>=25) result="Needs intentional development";
else result="Requires focused attention and growth";

document.getElementById("resultText").innerText=result;

}

</script>

</body>
</html>
